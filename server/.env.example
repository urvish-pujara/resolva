# Copy this file to `.env` for local development, or set these as
# environment variables on your host (Render, Fly, etc.). `.env` is git-ignored.

# Postgres connection string. Use a free Neon database in production
# (https://neon.tech). Locally, any Postgres URL works.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Comma-separated list of allowed origins for browser CORS.
# In production, set this to your deployed frontend URL (e.g. https://resolva.vercel.app).
# Leave unset locally — the Vite dev server proxies /api so CORS isn't needed.
CORS_ORIGIN=

# Google AI Studio key for Gemini (https://aistudio.google.com/apikey).
# Optional — without it, /api/ai/suggest-reply returns a clean 503.
GEMINI_API_KEY=

# Optional: model override. Defaults to gemini-2.0-flash.
# GEMINI_MODEL=gemini-2.0-flash

# Optional: override server port (defaults to 4000). Render sets PORT automatically.
# PORT=4000
